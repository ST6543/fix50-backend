:root{
  --bg:#1a1a1a;
  --card:#2f2f2f;
  --accent:#ff7b00;
  --accent-2:#ff6a00;
  --muted:#bdbdbd;
  --glass: rgba(255,255,255,0.03);
  --radius:12px;
  --shadow: 0 8px 24px rgba(0,0,0,0.55);
  --ease: cubic-bezier(.2,.9,.3,1);
}

*{box-sizing:border-box}
body{
  margin:0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  background:var(--bg);
  color:#fff;
  -webkit-font-smoothing:antialiased;
  line-height:1.45;
}

.wrap{max-width:980px;margin:0 auto;padding:28px}

.site-header{background:var(--accent);padding:18px 0;border-bottom:4px solid rgba(0,0,0,0.08)}
.site-header h1{margin:0;color:#fff;font-size:20px;text-align:center;font-weight:700;letter-spacing:0.4px}

.main-grid{display:grid;grid-template-columns:1fr;gap:18px;padding:28px 0}

/* Progress bar */
.progress {
  display:flex;
  gap:8px;
  align-items:center;
  margin-bottom:6px;
}
.progress .step {
  flex:1;
  height:8px;
  background:var(--glass);
  border-radius:8px;
  overflow:hidden;
  position:relative;
}
.progress .step .fill {
  position:absolute;left:0;top:0;bottom:0;width:0%;
  background:linear-gradient(90deg,var(--accent),var(--accent-2));
  transition: width .35s var(--ease);
}

/* Card */
.card{
  background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
  border-radius:var(--radius);
  padding:20px;
  box-shadow:var(--shadow);
  border:1px solid rgba(255,255,255,0.03);
}
.card h2{color:var(--accent);margin:0 0 12px 0;font-size:18px}

/* Buttons */
.btn{
  background:var(--accent);
  color:#fff;
  padding:12px 16px;
  border-radius:10px;
  border:none;
  cursor:pointer;
  font-weight:700;
  text-decoration:none;
  display:inline-flex;
  align-items:center;
  gap:10px;
  transition: transform .12s var(--ease), box-shadow .12s var(--ease), background .12s;
  box-shadow: 0 6px 18px rgba(0,0,0,0.35);
  min-height:44px;
}
.btn:hover{transform:translateY(-3px);background:var(--accent-2)}
.btn:active{transform:translateY(-1px)}
.btn:focus{outline:2px solid rgba(255,123,0,0.18);outline-offset:3px}

/* Ghost / secondary */
.btn.ghost{background:transparent;border:1px solid rgba(255,255,255,0.06);box-shadow:none;color:#fff}

/* Type grid */
.type-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-top:12px}
.type-grid .btn{justify-content:center;padding:14px}

/* Problem list */
.list-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-top:12px}
.list-grid .btn{justify-content:flex-start;padding:12px 14px}

/* Questions */
#questionBox p{margin:0 0 10px 0;color:var(--muted)}
#questionBox .btn{min-width:160px}

/* Result */
.result-text{font-size:15px;color:var(--muted);margin-top:8px}

/* Hidden */
.hidden{display:none}

/* Small screens */
@media(max-width:720px){
  .wrap{padding:18px}
  .site-header h1{font-size:18px}
  .card{padding:16px}
  .btn{min-height:42px;font-size:15px}
}
